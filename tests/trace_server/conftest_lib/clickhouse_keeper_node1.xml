<clickhouse>
    <!-- Embedded Keeper on node 1 -->
    <keeper_server>
        <tcp_port>9181</tcp_port>
        <server_id>1</server_id>
        <log_storage_path>/var/lib/clickhouse/coordination/log</log_storage_path>
        <snapshot_storage_path>/var/lib/clickhouse/coordination/snapshots</snapshot_storage_path>
        <coordination_settings>
            <operation_timeout_ms>10000</operation_timeout_ms>
            <session_timeout_ms>30000</session_timeout_ms>
            <raft_logs_level>warning</raft_logs_level>
        </coordination_settings>
        <raft_configuration>
            <server>
                <id>1</id>
                <hostname>ch-node1</hostname>
                <port>9234</port>
            </server>
        </raft_configuration>
    </keeper_server>

    <!-- Both nodes use node 1's embedded Keeper -->
    <zookeeper>
        <node>
            <host>ch-node1</host>
            <port>9181</port>
        </node>
    </zookeeper>

    <!-- Two-replica cluster definition -->
    <remote_servers>
        <weave_cluster>
            <shard>
                <replica>
                    <host>ch-node1</host>
                    <port>9000</port>
                </replica>
                <replica>
                    <host>ch-node2</host>
                    <port>9000</port>
                </replica>
            </shard>
        </weave_cluster>
    </remote_servers>

    <macros>
        <shard>shard1</shard>
        <replica>replica1</replica>
    </macros>
</clickhouse>
