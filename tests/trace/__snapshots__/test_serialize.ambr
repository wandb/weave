# serializer version: 1
# name: test_dictify_complex
  dict({
    '__class__': dict({
      'module': 'test_serialize',
      'name': 'Points',
      'qualname': 'test_dictify_complex.<locals>.Points',
    }),
    'points': list([
      dict({
        '__class__': dict({
          'module': 'test_serialize',
          'name': 'Point',
          'qualname': 'test_dictify_complex.<locals>.Point',
        }),
        'x': 1,
        'y': 2,
      }),
      dict({
        '__class__': dict({
          'module': 'test_serialize',
          'name': 'Point',
          'qualname': 'test_dictify_complex.<locals>.Point',
        }),
        'x': 3,
        'y': 4,
      }),
    ]),
  })
