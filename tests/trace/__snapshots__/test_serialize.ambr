# name: test_to_json_pydantic_class
  dict({
    'properties': dict({
      'date': dict({
        'title': 'Date',
        'type': 'string',
      }),
      'name': dict({
        'title': 'Name',
        'type': 'string',
      }),
      'participants': dict({
        'items': dict({
          'type': 'string',
        }),
        'title': 'Participants',
        'type': 'array',
      }),
    }),
    'required': list([
      'name',
      'date',
      'participants',
    ]),
    'title': 'CalendarEvent',
    'type': 'object',
  })
